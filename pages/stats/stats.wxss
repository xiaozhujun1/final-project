/* pages/stats/stats.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.overview {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.overview-value.completed {
  color: #52c41a;
}

.overview-value.pending {
  color: #1890ff;
}

.overview-label {
  font-size: 26rpx;
  color: #999;
}

.rate-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.rate-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.rate-title {
  font-size: 28rpx;
  color: #666;
}

.rate-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #52c41a;
}

.rate-bar {
  height: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
}

.rate-progress {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #73d13d);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-count {
  font-size: 24rpx;
  color: #999;
}

.category-bar {
  height: 12rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
  overflow: hidden;
}

.category-progress {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #69c0ff);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.priority-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.priority-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.priority-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.priority-tag.priority-high {
  background: #fff1f0;
  color: #ff4d4f;
}

.priority-tag.priority-mid {
  background: #fff7e6;
  color: #faad14;
}

.priority-tag.priority-low {
  background: #f6ffed;
  color: #52c41a;
}

.priority-bar-wrap {
  flex: 1;
}

.priority-bar {
  height: 12rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
  overflow: hidden;
}

.priority-progress {
  height: 100%;
  background: linear-gradient(90deg, #722ed1, #b37feb);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.priority-count {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  width: 40rpx;
  text-align: right;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  color: #ccc;
  font-size: 26rpx;
}

.backup-entry {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  text-align: center;
  color: #1890ff;
  font-size: 28rpx;
  margin-top: 20rpx;
}
