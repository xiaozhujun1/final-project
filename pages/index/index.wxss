/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 26rpx;
  color: #999;
  padding-left: 16rpx;
}

.search-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 16rpx;
}

.filter-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
}

.filter-item.active {
  background: #1890ff;
  color: #fff;
}

.sort-picker {
  margin-left: 16rpx;
}

.sort-btn {
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.stats {
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  font-size: 26rpx;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.stats-arrow {
  color: #1890ff;
  font-size: 24rpx;
}

.todo-list {
  padding-bottom: 120rpx;
}

.todo-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #d9d9d9;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.check-circle.checked {
  background: #52c41a;
  border-color: #52c41a;
  position: relative;
}

.check-circle.checked::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 6rpx;
  width: 12rpx;
  height: 20rpx;
  border: 3rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.todo-item.completed .todo-title {
  text-decoration: line-through;
  color: #999;
}

.todo-content {
  flex: 1;
}

.todo-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.todo-meta {
  display: flex;
  gap: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tag-work { background: #fff7e6; color: #faad14; }
.tag-life { background: #e6f7ff; color: #1890ff; }
.tag-study { background: #f6ffed; color: #52c41a; }
.tag-other { background: #f9f9f9; color: #666; }

.priority {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.priority-high { background: #fff1f0; color: #ff4d4f; }
.priority-mid { background: #fff7e6; color: #faad14; }
.priority-low { background: #f6ffed; color: #52c41a; }

.deadline {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background: #f5f5f5;
  color: #666;
}

.deadline-overdue {
  background: #fff1f0;
  color: #ff4d4f;
}

.todo-item.overdue {
  border-left: 6rpx solid #ff4d4f;
}

.remark {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  line-height: 1.4;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  color: #ccc;
  font-size: 26rpx;
}

.add-btn {
  position: fixed;
  bottom: 60rpx;
  right: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 50%;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.4);
}
