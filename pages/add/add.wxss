/* pages/add/add.wxss */
.container {
  padding: 20rpx;
}

.form-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.input {
  font-size: 30rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
}

.picker {
  font-size: 30rpx;
  color: #333;
  width: 100%;
}

.picker.placeholder {
  color: #999;
}

.deadline-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.deadline-row .picker {
  flex: 1;
}

.clear-btn {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}

.remark-input {
  font-size: 28rpx;
  color: #333;
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.btn-save {
  background: #1890ff;
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
  width: 100%;
  box-sizing: border-box;
}
