<view class="container">
  <!-- 数据概览 -->
  <view class="card">
    <view class="card-title">数据概览</view>
    <view class="info-row">
      <text class="info-label">任务总数</text>
      <text class="info-value">{{todoCount}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">上次备份</text>
      <text class="info-value">{{lastBackupTime ? lastBackupTime : '从未备份'}}</text>
    </view>
  </view>

  <!-- 备份导出 -->
  <view class="card">
    <view class="card-title">备份与导出</view>
    <view class="action-item" bindtap="exportData">
      <view class="action-icon">📤</view>
      <view class="action-content">
        <text class="action-title">导出数据</text>
        <text class="action-desc">将任务数据复制到剪贴板</text>
      </view>
    </view>
    <view class="action-item" bindtap="importData">
      <view class="action-icon">📥</view>
      <view class="action-content">
        <text class="action-title">导入数据</text>
        <text class="action-desc">从剪贴板恢复任务数据</text>
      </view>
    </view>
  </view>

  <!-- 危险操作 -->
  <view class="card danger">
    <view class="card-title">危险操作</view>
    <view class="action-item" bindtap="clearData">
      <view class="action-icon">🗑️</view>
      <view class="action-content">
        <text class="action-title danger-text">清空所有数据</text>
        <text class="action-desc">删除所有任务，不可恢复</text>
      </view>
    </view>
  </view>
</view>
