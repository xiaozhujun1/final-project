<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索任务标题或备注" 
      value="{{searchKey}}"
      bindinput="onSearchInput"
    />
    <view wx:if="{{isSearching}}" class="search-clear" bindtap="onSearchClear">清除</view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view 
      wx:for="{{categories}}" 
      wx:key="index"
      class="filter-item {{filterIndex === index ? 'active' : ''}}"
      bindtap="onFilterTap"
      data-index="{{index}}"
    >
      {{item}}
    </view>
    <picker 
      class="sort-picker"
      mode="selector"
      range="{{sortOptions}}"
      value="{{sortIndex}}"
      bindchange="onSortChange"
    >
      <view class="sort-btn">排序：{{sortOptions[sortIndex]}}</view>
    </picker>
  </view>

  <!-- 统计 -->
  <view class="stats" bindtap="goToStats">
    <text>已完成 {{completedCount}} / {{todos.length}}</text>
    <text class="stats-arrow">查看详情</text>
  </view>

  <!-- 搜索结果提示 -->
  <view wx:if="{{isSearching}}" class="search-tip">
    <text>搜索到 {{filteredTodos.length}} 个结果</text>
  </view>

  <!-- 任务列表 -->
  <view class="todo-list">
    <view 
      wx:for="{{filteredTodos}}" 
      wx:key="createTime"
      class="todo-item {{item.completed ? 'completed' : ''}} {{item.hasDeadline && item.deadline < today && !item.completed ? 'overdue' : ''}}"
      bindtap="onTodoTap"
      bindlongpress="onLongPress"
      data-index="{{index}}"
    >
      <view class="check-circle {{item.completed ? 'checked' : ''}}"></view>
      <view class="todo-content">
        <view class="todo-title">{{item.title}}</view>
        <view class="todo-meta">
          <text class="tag tag-{{item.category}}">{{item.category}}</text>
          <text class="priority priority-{{item.priority}}">{{item.priority}}</text>
          <text wx:if="{{item.hasDeadline}}" class="deadline {{item.deadline < today && !item.completed ? 'deadline-overdue' : ''}}">
            {{item.deadline}}
          </text>
        </view>
        <view wx:if="{{item.remark}}" class="remark">
          {{item.remark.length > 30 ? item.remark.substring(0, 30) + '...' : item.remark}}
        </view>
      </view>
    </view>

    <view wx:if="{{filteredTodos.length === 0 && !isSearching}}" class="empty">
      <view class="empty-icon">📝</view>
      <text class="empty-text">暂无待办事项</text>
      <text class="empty-hint">点击右下角 + 添加新任务</text>
    </view>

    <view wx:if="{{filteredTodos.length === 0 && isSearching}}" class="empty">
      <view class="empty-icon">🔍</view>
      <text class="empty-text">未找到相关任务</text>
      <text class="empty-hint">尝试其他关键词</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="onAddTap">+</view>
</view>
