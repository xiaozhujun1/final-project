<view class="container">
  <view class="form-item">
    <view class="label">任务标题</view>
    <input 
      class="input" 
      placeholder="请输入任务标题" 
      value="{{title}}"
      bindinput="onTitleInput"
    />
  </view>

  <view class="form-item">
    <view class="label">任务分类</view>
    <picker 
      mode="selector" 
      range="{{categories}}"
      value="{{categoryIndex}}"
      bindchange="onCategoryChange"
    >
      <view class="picker">
        {{categories[categoryIndex]}}
      </view>
    </picker>
  </view>

  <view class="form-item">
    <view class="label">优先级</view>
    <picker 
      mode="selector" 
      range="{{priorities}}"
      value="{{priorityIndex}}"
      bindchange="onPriorityChange"
    >
      <view class="picker">
        {{priorities[priorityIndex]}}
      </view>
    </picker>
  </view>

  <view class="form-item">
    <view class="label">截止日期</view>
    <view class="deadline-row">
      <picker 
        mode="date"
        value="{{deadline}}"
        bindchange="onDeadlineChange"
      >
        <view class="picker {{hasDeadline ? '' : 'placeholder'}}">
          {{hasDeadline ? deadline : '选择日期'}}
        </view>
      </picker>
      <view wx:if="{{hasDeadline}}" class="clear-btn" bindtap="onClearDeadline">清除</view>
    </view>
  </view>

  <view class="btn-save" bindtap="onSave">保存</view>
</view>
